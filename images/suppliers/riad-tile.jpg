  <!-- BEGIN app snippet: customer-hub-replace-links -->
<script>
  function replaceAccountLinks() {
    const selector =
      'a[href$="/account/login"], a[href$="/account"], a[href^="https://shopify.com/"][href*="/account"], a[href*="/customer_identity/redirect"], a[href*="/customer_authentication/redirect"], a[href$="/account';
    const accountLinksNodes = document.querySelectorAll(selector);
    for (const node of accountLinksNodes) {
      const ignore = node.dataset.kHubIgnore !== undefined && node.dataset.kHubIgnore !== 'false';
      if (!ignore) {
        // Any login links to Shopify's account system, point them at the customer hub instead.
        node.href = '#k-hub';
        /**
         * There are some themes which apply a page transition on every click of an anchor tag (usually a fade-out) that's supposed to be faded back in when the next page loads.
         * However, since clicking the k-hub link doesn't trigger a page load, the page gets stuck on a blank screen.
         * Luckily, these themes usually have a className you can add to links to skip the transition.
         * Let's hope that all such themes are consistent/copy each other and just proactively add those classNames when we replace the link.
         **/
        node.classList.add('no-transition', 'js-no-transition');
      }
    }
  }

  
    if (document.readyState === 'complete') {
      replaceAccountLinks();
    } else {
      const controller = new AbortController();
      document.addEventListener(
        'readystatechange',
        () => {
          replaceAccountLinks(); // try to replace links both during `interactive` state and `complete` state
          if (document.readyState === 'complete') {
            // readystatechange can fire with "complete" multiple times per page load, so make sure we're not duplicating effort
            // by removing the listener afterwards.
            controller.abort();
          }
        },
        { signal: controller.signal },
      );
    }
  
</script>
<!-- END app snippet -->



  <!-- BEGIN app snippet: klaviyo-personalization -->  <script>
  (function () {

    const dismissedBanners = JSON.parse(localStorage.getItem('kl_dismissed_banners') || '[]');
    const dismissedGroups = JSON.parse(localStorage.getItem('kl_dismissed_groups') || '[]');

    // Immediately hide dismissed banners and carousel groups (no flash)
    if (dismissedBanners.length || dismissedGroups.length) {
      const rules = dismissedBanners
        .map(function (id) { return '[data-banner-id="' + id + '"]{display:none!important}'; });
      dismissedGroups.forEach(function (gid) {
        rules.push('[data-banner-group-id="' + gid + '"]{display:none!important}');
      });
      const sheet = document.createElement('style');
      sheet.textContent = rules.join('\n');
      document.head.appendChild(sheet);
    }

    // ── Helpers ───────────────────────────────────────────────────────────────
    function storeDismissed(id) {
      const stored = JSON.parse(localStorage.getItem('kl_dismissed_banners') || '[]');
      if (!stored.includes(id)) {
        stored.push(id);
        localStorage.setItem('kl_dismissed_banners', JSON.stringify(stored));
      }
    }

    function storeDismissedGroup(groupId) {
      const stored = JSON.parse(localStorage.getItem('kl_dismissed_groups') || '[]');
      if (!stored.includes(groupId)) {
        stored.push(groupId);
        localStorage.setItem('kl_dismissed_groups', JSON.stringify(stored));
      }
    }

    function reinitCarousel(carousel) {
      const slides = carousel.querySelectorAll('.kl-carousel-slide');
      if (!slides.length) { carousel.remove(); return; }
      const idx = Math.min(parseInt(carousel.getAttribute('data-kl-slide') || '0'), slides.length - 1);
      carousel.setAttribute('data-kl-slide', idx);
    }

    // R2: remove slides for dismissed banners inside a carousel, then reinit
    function cleanupDismissedSlides() {
      if (!dismissedBanners.length) return;
      dismissedBanners.forEach(function (id) {
        const banner = document.querySelector('[data-banner-id="' + id + '"]');
        if (!banner) return;
        const carousel = banner.closest('.kl-carousel');
        if (!carousel) return;
        const slide = banner.closest('.kl-carousel-slide');
        if (slide) slide.remove();
      });
      document.querySelectorAll('.kl-carousel').forEach(reinitCarousel);
    }

    // ── Auto-scroll ─────────────────────────────────────────────────────────
    function initAutoScroll() {
      document.querySelectorAll('.kl-carousel[data-scroll-delay]').forEach(function (carousel) {
        if (carousel.hasAttribute('data-autoscroll-init')) return;
        carousel.setAttribute('data-autoscroll-init', '1');
        const delay = parseInt(carousel.getAttribute('data-scroll-delay') || '5000');
        const total = carousel.querySelectorAll('.kl-carousel-slide').length;
        if (total <= 1) return;

        let timer;
        function advance() {
          const current = parseInt(carousel.getAttribute('data-kl-slide') || '0');
          const next = (current + 1) % total;
          if (current === total - 1) {
            carousel.classList.add('kl-carousel-wrapping');
            setTimeout(function () { carousel.classList.remove('kl-carousel-wrapping'); }, 350);
          }
          carousel.setAttribute('data-kl-slide', String(next));
        }
        function resetTimer() {
          clearInterval(timer);
          timer = setInterval(advance, delay);
        }
        resetTimer();

        carousel.addEventListener('click', function (e) {
          if (e.target.closest('[data-kl-action^="carousel-"]')) resetTimer();
        });
      });
    }

    // Watch for carousels injected after DOMContentLoaded (Customer Hub does this)
    const observer = new MutationObserver(function (mutations) {
      const hasCarousel = mutations.some(function (m) {
        return Array.from(m.addedNodes).some(function (n) {
          return n.nodeType === 1 && (
            (n.classList && n.classList.contains('kl-carousel')) ||
            (n.querySelector && n.querySelector('.kl-carousel'))
          );
        });
      });
      if (hasCarousel) {
        cleanupDismissedSlides();
        initAutoScroll();
      }
    });

    observer.observe(document.documentElement, { childList: true, subtree: true });

    // Also run immediately in case carousels are already present
    cleanupDismissedSlides();
    initAutoScroll();

    // ── Carousel navigation ───────────────────────────────────────────────────
    // CSS handles slide visibility via data-kl-slide attribute selectors
    // (per-slide opacity/transform). No track-level transform needed.
    document.addEventListener('click', function (e) {
      const btn = e.target.closest('[data-kl-action^="carousel-"]');
      if (!btn) return;
      e.stopPropagation();
      const carousel = btn.closest('.kl-carousel');
      if (!carousel) return;
      const slides = carousel.querySelectorAll('.kl-carousel-slide');
      let i = parseInt(carousel.getAttribute('data-kl-slide') || '0');
      i = btn.getAttribute('data-kl-action') === 'carousel-prev'
        ? (i - 1 + slides.length) % slides.length
        : (i + 1) % slides.length;
      carousel.setAttribute('data-kl-slide', i);
    });

    // ── Banner dismiss ────────────────────────────────────────────────────────
    window.dismissKlaviyoPersonalizationBanner = function (event) {
      event.stopPropagation();
      const banner = event.target.closest('[data-banner-id]');
      const carousel = event.target.closest('.kl-carousel');

      // R1 — standalone banner (dismiss button inside [data-banner-id])
      if (banner && !carousel) {
        storeDismissed(banner.dataset.bannerId);
        banner.style.display = 'none';
        return;
      }

      // R2 — carousel-level dismiss: hide the entire carousel
      if (carousel) {
        carousel.querySelectorAll('[data-banner-id]').forEach(function (b) {
          storeDismissed(b.dataset.bannerId);
        });
        const groupId = carousel.getAttribute('data-banner-group-id');
        if (groupId) storeDismissedGroup(groupId);
        carousel.style.display = 'none';
        return;
      }
    };

  }());
</script>

<script>
  (function () {
    // ===== Config =====
    const SHOP_PERMANENT_DOMAIN = "e20de9-16.myshopify.com";
    const FASTLY_PREFIX = 'https://fast.a.klaviyo.com/atlas/'
    const PERSONALIZATION_URL = `${FASTLY_PREFIX}api/public/personalization?`;

    const TARGET_ELEMENT_ID = "p13n-block";

    // ===== LocalStorage helpers =====
    function safeLocalGet(key) {
      try {
        return window.localStorage.getItem(key);
      } catch (e) {
        return null;
      }
    }


    // ===== SessionStorage helpers =====
    function safeSessionGet(key) {
      try {
        return window.sessionStorage.getItem(key);
      } catch (e) {
        return null;
      }
    }

    // ===== _kx token helpers =====
    function getKxFromLearnq() {
      try {
        if (!window._learnq) return null;

        // Get identifiers from _learnq
        const identifiers = window._learnq.push(['_getIdentifiers']);

        // _learnq.push returns a number if the method doesn't exist, or the result object
        if (typeof identifiers === 'number' || !identifiers) return null;

        return identifiers.$exchange_id || null;
      } catch (e) {
        return null;
      }
    }

    function getKxFromSession() {
      const encoded = safeSessionGet("_kx");
      if (!encoded) return null;

      try {
        return window.atob(encoded); // base64 decode
      } catch (e) {
        return null;
      }
    }

    function getKxFromUrl() {
      // Try URLSearchParams first
      try {
        const params = new URLSearchParams(window.location.search);
        const fromParams = params.get("_kx");
        if (fromParams) {
          return decodeURIComponent(fromParams);
        }
      } catch (e) {
        // ignore
      }

      // Fallback: regex
      const match = window.location.search.match(/(?:\?|&)_kx=([^&#]+)/i);
      if (match && match[1]) {
        return decodeURIComponent(match[1]);
      }

      return null;
    }

    function getKxToken() {
      // 1. Primary source: _learnq (most up-to-date, managed by klaviyo.js)
      let kxToken = getKxFromLearnq();
      if (kxToken) return kxToken;

      // 2. Fast path: already in sessionStorage
      kxToken = getKxFromSession();
      if (kxToken) return kxToken;

      // 3. First page in session: look in URL
      kxToken = getKxFromUrl();
      if (!kxToken) return null;

      return kxToken;
    }

    // ===== Personalization loader =====
    async function loadPersonalization() {
      const kx = getKxToken();
      const atlasToken = safeLocalGet('atlas_token');
      const headers = {};

      // Add _kx token if available (identified user)
      if (kx) {
        headers["x-klaviyo-fingerprint"] = kx;
      }

      // Add atlas token if available (logged in user)
      if (atlasToken) {
        headers["Authorization"] = `Bearer ${atlasToken}`;
      }

      try {
        const locale = 'en'
        const params = new URLSearchParams({
          "store_domain": SHOP_PERMANENT_DOMAIN,
          "locale": locale,
          "kx": kx,
          "logged_in": !!atlasToken,
        });

        const locale_aware_personalization_url = `${PERSONALIZATION_URL}${params.toString()}`
        const res = await fetch(locale_aware_personalization_url, {
          method: "GET",
          headers
        });

        if (!res.ok) {
          return;
        }

        const html = await res.text();

        // Create and append the target element if it doesn't exist
        let el = document.getElementById(TARGET_ELEMENT_ID);
        if (!el) {
          el = document.createElement('div');
          el.id = TARGET_ELEMENT_ID;
          document.body.insertBefore(el, document.body.firstChild);
        }

        el.innerHTML = html;

        // Propagate sticky positioning to the wrapper so it works
        // relative to the viewport scroll container (body).
        // Detect: new attribute (data-kl-sticky), transitional (data-sticky),
        // or old inline style (position: sticky) for backward compat.
        if (el.querySelector('[data-kl-sticky], [data-sticky], [style*="position: sticky"], [style*="position:sticky"]')) {
          el.style.position = 'sticky';
          el.style.top = '0';
          el.style.zIndex = '1000';
        }
      } catch (e) {
        console.error("[p13n] Personalization load failed", e);
      }
    }

    // Run after DOM is ready enough to find the target element
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", loadPersonalization);
    } else {
      loadPersonalization();
    }
  })();
</script>
