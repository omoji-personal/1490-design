<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Select all product titles within the .collection-product-list
    var productTitles = document.querySelectorAll('.collection-product-list .card__title.h5');

    // Loop through each product title
    productTitles.forEach(function(titleElement) {
      // Convert the text to lowercase and check if it contains the word 'sample'
      if (titleElement.innerText.toLowerCase().includes('sample')) {
        // Find the closest product container and hide it
        var productCard = titleElement.closest('.grid__item'); // Adjust this to match your product card structure
        if (productCard) {
          productCard.style.display = 'none';
        }
      }
    });
  });
</script>



<script>
    // For Collection template with collapsible content
document.addEventListener("DOMContentLoaded", function () {
    // Check if the current page is a collection page by looking for '/collections/' in the URL path
    if (window.location.pathname.includes("/collections/")) {
        // Select all collapsible content items
        const collapsibleItems = document.querySelectorAll(".collapsible-content__item");

        collapsibleItems.forEach(item => {
            // Select the answer and icon within the current item
            const answer = item.querySelector(".collapsible-content__answer");
            const icon = item.querySelector(".collapsible-content__icon");

            // Remove the 'active' class to ensure the item is closed
            item.classList.remove("active");

            // Close the answer by default
            if (answer) {
                answer.style.display = "none"; // Ensure the answer is closed by default
            }

            // If the icon exists, set it to inactive state
            if (icon) {
                icon.classList.remove("active"); // Adjust as needed to set inactive state
            }

            // Add click event listener to toggle the collapsible content
            const toggleButton = item.querySelector(".collapsible-toggle-button"); // Adjust selector to your toggle button
            if (toggleButton) {
                toggleButton.addEventListener("click", function () {
                    // Toggle the display of the answer
                    if (answer) {
                        if (answer.style.display === "none") {
                            answer.style.display = "block"; // Open the answer
                            icon.classList.add("active"); // Mark the icon as active
                            item.classList.add("active"); // Mark the item as active
                        } else {
                            answer.style.display = "none"; // Close the answer
                            icon.classList.remove("active"); // Remove active state from the icon
                            item.classList.remove("active"); // Mark the item as inactive
                        }
                    }
                });
            }
        });

        // Create a style element for the additional CSS
        const style = document.createElement("style");
        style.innerHTML = `
            .collapsible-content-wrapper {
                display: flex;
                justify-content: space-between;
                width: 100%;
            }

            /* First column placeholder (1fr) */
            .first-column-placeholder {
                flex: 1;
            }

            /* Collapsible content (3fr) */
            .collapsible-content {
                flex: 3;
                margin-left: 0;
                padding: 20px;
                margin-bottom: 100px;
            }

            /* Responsive margin-left settings */
            @media (min-width: 320px) {
                .collapsible-content {
                    margin-left: 20px;
                }
            }

            @media (min-width: 768px) {
                .collapsible-content {
                    margin-left: 40px;
                }
            }

            @media (min-width: 1024px) {
                .collapsible-content {
                    margin-left: 440px;
                }
            }
            @media (min-width: 1366px) {
                .collapsible-content {
                    margin-left: 290px;
                }
            }
            @media (min-width: 1600px) {
                .collapsible-content {
                    margin-left: 350px;
                }
            }
            @media (min-width: 1800px) {
                .collapsible-content {
                    margin-left: 400px;
                }
            }
            @media (min-width: 1920px) {
                .collapsible-content {
                    margin-left: 430px;
                }
            }
            @media (min-width: 2100px) {
                .collapsible-content {
                    margin-left: 520px;
                }
            }
            @media (min-width: 2400px) {
                .collapsible-content {
                    margin-left: 660px;
                }
            }

            /* Optional: Ensure responsive design */
            @media (max-width: 768px) {
                .collapsible-content-wrapper {
                    flex-direction: column;
                }
            }
        `;
        // Append the style element to the head of the document
        document.head.appendChild(style);
    }
});
</script>



